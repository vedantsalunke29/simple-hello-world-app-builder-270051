FROM node:22.17.0-alpine
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable && corepack install --global pnpm@10.27.0
ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0

RUN apk add --no-cache openssl
RUN apk add --no-cache git

# Copy entrypoint script
COPY entrypoint.publish.sh /entrypoint.publish.sh
RUN chmod +x /entrypoint.publish.sh

WORKDIR /app/project

# Copy package files
COPY package.json .
COPY pnpm-lock.yaml .

# Install dependencies (including dev dependencies for build)
RUN pnpm install

# Copy source files needed for build
COPY . .

# Generate Prisma client
RUN pnpm dbGenerate

# Build the project
RUN pnpm build

RUN cp -r src/generated ./dist/generated

# Remove dev dependencies to reduce image size
RUN pnpm prune --production

EXPOSE 3000

# Set production environment
ENV NODE_ENV=production

# Use entrypoint script to run migrations and start server
ENTRYPOINT ["/entrypoint.publish.sh"]

