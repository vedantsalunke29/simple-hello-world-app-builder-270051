{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "jsx": "react-native",
        "strict": true,
        "noEmit": true,
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": ["node"]
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "app.config.ts", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
